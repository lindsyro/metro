generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Таблица инцидентов
model Incident {
  id            Int       @id @default(autoincrement())
  status        String    @default("active") // "active", "resolved", "canceled"
  incidentType  String    // "дтп", "обрыв_сети", "поломка" и т.д.
  transportType String?   // "tram", "trolleybus", "bus" (опционально)
  routes        String[]  // Массив маршрутов (например, ["4", "7"])
  location      String?   // Участок (опционально)
  
  createdAt     DateTime  @default(now())
  resolvedAt    DateTime?
}
